# UE5 Remote Control API base URL (default: http://127.0.0.1:30010)
UE5_RC_URL=http://127.0.0.1:30010

# Absolute path to your UE5 project Source directory
UE5_PROJECT_SOURCE=C:\Github\myProject\Source

# Absolute path to UE5 output log file
UE5_LOG_PATH=C:\Github\myProject\Saved\Logs\myProject.log

# Optional shared secret for X-MCP-Secret header (HTTP transport authentication)
MCP_SECRET=

# Must be exactly "true" to enable file write tools (ue5_stage_files, ue5_commit_files)
UE5_ALLOW_FILE_WRITE=false

# Comma-separated extension whitelist for file writes
UE5_WRITE_EXTENSIONS=.cpp,.h

# Staging TTL in milliseconds before a staged batch expires (default: 10 minutes)
UE5_STAGING_TTL_MS=600000
